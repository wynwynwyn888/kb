# =============================================================================
# .env.staging.example  —  TEMPLATE ONLY (KB / aisbp local staging)
# =============================================================================
#
#   HOW TO USE
#     1. Copy this file to `.env.staging`  (cp .env.staging.example .env.staging)
#     2. Fill in values from your STAGING Supabase project only.
#     3. `.env.staging` is git-ignored. NEVER commit it.
#
#   SAFETY WARNINGS
#     * NEVER paste real secrets into ChatGPT, issues, PRs, or chat.
#     * NEVER commit real secrets. `.env.staging` must stay local.
#     * Use a SEPARATE staging Supabase project. NEVER point staging at the
#       production database, production Supabase, or production keys.
#     * These ports (frontend 3002 / backend 3003 / redis 6380) are local-only
#       and intentionally differ from dev (3000/3001/6379) and production.
#
#   This template contains placeholders only — no real values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (STAGING Supabase Postgres ONLY — never production)
# -----------------------------------------------------------------------------
# Read by docker-compose.staging.yml interpolation (${STAGING_DATABASE_URL}).
# If left unset, the compose file falls back to an INVALID local DSN so a
# misconfigured run can never silently reach a real/production database.
# Use the STAGING Supabase connection string only.
STAGING_DATABASE_URL="postgresql://postgres:<staging-db-password>@<staging-db-host>:5432/postgres?schema=public"

# -----------------------------------------------------------------------------
# Supabase Auth (STAGING project)
# -----------------------------------------------------------------------------
SUPABASE_URL="<staging-supabase-url>"
SUPABASE_ANON_KEY="<staging-supabase-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<staging-supabase-service-role-key>"

# Browser-exposed Supabase values (must match the staging project above)
NEXT_PUBLIC_SUPABASE_URL="<staging-supabase-url>"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<staging-supabase-anon-key>"

# -----------------------------------------------------------------------------
# Redis / Queue (isolated staging instance)
# -----------------------------------------------------------------------------
# Inside the compose network the backend talks to the `redis` service on 6379;
# these are pinned by the compose file. QUEUE_PREFIX is forced to `staging`.
REDIS_HOST="redis"
REDIS_PORT="6379"
QUEUE_PREFIX="staging"

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
NODE_ENV="staging"
API_PREFIX="api/v1"
APP_TIMEZONE="Asia/Singapore"

# Public app origin (local staging frontend)
NEXT_PUBLIC_APP_URL="http://localhost:3002"
NEXT_PUBLIC_APP_TIMEZONE="Asia/Singapore"

# CORS — allow the local staging frontend origin only
CORS_ORIGIN="http://localhost:3002"

# Rate limiting
RATE_LIMIT_TTL="60000"
RATE_LIMIT_MAX="100"

# -----------------------------------------------------------------------------
# Secrets (generate fresh STAGING-only values — never reuse production secrets)
# -----------------------------------------------------------------------------
JWT_SECRET="<staging-jwt-secret-min-32-chars>"
JWT_EXPIRES_IN="7d"
# Must be exactly 32 UTF-8 characters. Generate a fresh staging value.
ENCRYPTION_KEY="<staging-32-char-encryption-key>"
WEBHOOK_SIGNATURE_SECRET="<staging-webhook-hmac-secret>"

# -----------------------------------------------------------------------------
# Integrations (leave blank for basic staging; fill with STAGING credentials
# only if you are testing those flows — never production credentials)
# -----------------------------------------------------------------------------
GHL_API_BASE_URL="https://services.leadconnectorhq.com"
GHL_CLIENT_ID=""
GHL_CLIENT_SECRET=""
GHL_REDIRECT_URI="http://localhost:3003/api/v1/ghl/oauth/callback"

OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
