# Database (Postgres via Supabase)
# Local: postgresql://postgres:postgres@localhost:54322/postgres
# Production: Use your Supabase project connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres?schema=public"

# Supabase Auth
# Local: http://localhost:54321
# Production: https://kb.aisalesbot.pro (Supabase manages this)
SUPABASE_URL="http://localhost:54321"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Inbound message debounce before AI orchestration (batch rapid lines). Integer ms, clamped 750–10000; invalid/missing → 2000.
# AISBP_INBOUND_DEBOUNCE_MS=2000

# Redis (local: host/port only; managed e.g. Render Key Value: set REDIS_USER, REDIS_PASSWORD, REDIS_TLS=true)
REDIS_HOST="localhost"
REDIS_PORT="6379"
# REDIS_USER=""
# REDIS_PASSWORD=""
# REDIS_TLS="false"

# JWT (for internal operations, Supabase handles primary auth)
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# Auth API: /auth/me requires a Supabase JWT by default. Optional strict profile row check:
# - unset or not "1": allow session if JWT validates (no profiles row required)
# - "1": reject if no row in `profiles` for this user
# AUTH_REQUIRE_PROFILE="1"
# AUTH_DEBUG="1"

# Local dev only — used by `npm run smoke:auth` / `npm run smoke:auth:write` (never commit real credentials)
# SMOKE_AUTH_EMAIL="dev-user@example.com"
# SMOKE_AUTH_PASSWORD=""
# Optional: override API base (default http://127.0.0.1:$PORT/$API_PREFIX)
# SMOKE_API_BASE_URL="http://127.0.0.1:3001/api/v1"

# GHL API (not yet implemented)
# HighLevel (GoHighLevel) API — use services.leadconnectorhq.com (not *.gohighlevel.com; that host does not resolve)
GHL_API_BASE_URL="https://services.leadconnectorhq.com"
# Experimental: when inbound workflow sends AUDIO/[AUDIO] placeholders with no media URL, optionally GET recording bytes by message id (default off).
GHL_VOICE_FETCH_RECORDING_BY_MESSAGE_ID=false
# Workflow-flat placeholders often omit messageId — list conversation messages after a delay, locate placeholder row, then call recording endpoint (default off).
GHL_VOICE_DISCOVER_MESSAGE_ID=false
# Default 1500ms when unset; set explicitly to override.
GHL_VOICE_DISCOVER_DELAY_MS=1500
GHL_VOICE_DISCOVER_MAX_ATTEMPTS=2
# When workflow-flat omits externalConversationId, discover recent conversationId by contactId before message-id discovery (default off).
GHL_VOICE_DISCOVER_CONVERSATION_ID=false
GHL_VOICE_DISCOVER_CONVERSATION_LIMIT=10
# Voice note discovery diagnostics (default off). When enabled, logs include redacted `latestMessageSamples` with attachment/media shape samples.
GHL_VOICE_DEBUG_SHAPES=false

# Inbound GHL webhook logging (NODE_ENV=production defaults these off when unset)
# GHL_WEBHOOK_SHAPE_DIAGNOSTICS=false
# GHL_WEBHOOK_LOG_BODY_KEYS=false

# Outbound reply whitespace diagnostics (default off in production when unset)
# OUTBOUND_WHITESPACE_DEBUG=false

# Runtime prompt size INFO log (set to false to suppress footprint line)
# PROMPT_FOOTPRINT_DEBUG=true

# Production defaults for GET /calendars/:id/free-slots (services API day window). Override only if needed.
# GHL_FREE_SLOTS_HOST_MODE=services_api
#   widget_backend — fallback/diagnostic only (`backend.leadconnectorhq.com`; use Automation → Advanced diagnostics probe)
# GHL_FREE_SLOTS_RANGE_MODE=day
#   month | day | selected_to_day_end — query window when HOST_MODE=widget_backend; services_api uses the caller day range
# GHL_FREE_SLOTS_SEND_SEATS_PER_SLOT=false
# GHL_FREE_SLOTS_CHANNEL=APP
# GHL_FREE_SLOTS_SOURCE=WEB_USER
# GHL_FREE_SLOTS_WIDGET_USE_BEARER=false
# GHL_FREE_SLOTS_WIDGET_PROBE_WITH_BEARER=false
# GHL_FREE_SLOTS_API_VERSION=2023-02-21
# GHL_FREE_SLOTS_TIMESTAMP_UNIT=ms
# GHL_FREE_SLOTS_INCLUDE_TIMEZONE=true
# GHL_FREE_SLOTS_RETRY_USER_PARAM=userId
#
# POST .../probe-free-slots (JWT): in NODE_ENV=production requires ALLOW_BOOKING_PROBE=true (rate-limited).
# ALLOW_BOOKING_PROBE=true

GHL_CLIENT_ID=""
GHL_CLIENT_SECRET=""
GHL_REDIRECT_URI="https://kb.aisalesbot.pro/api/v1/ghl/oauth/callback"

# AI Providers (not yet implemented)
OPENAI_API_KEY=""
# GHL inbound voice notes: OpenAI `/v1/audio/transcriptions` model (speech-to-text before orchestration).
OPENAI_TRANSCRIBE_MODEL="gpt-4o-mini-transcribe"
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# Encryption (for sensitive data like GHL tokens)
# REQUIRED: Must be exactly 32 UTF-8 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then convert hex to UTF-8 string for this value
ENCRYPTION_KEY="your-32-byte-encryption-key-here"

# Development override - DO NOT USE IN PRODUCTION
# Allows insecure fallback key for local dev when ENCRYPTION_KEY is not set
# Set to "true" only for local development without encryption configured
ALLOW_INSECURE_DEV_KEY="false"

# App
NODE_ENV="development"
# Listen port. `pnpm dev` in apps/backend strips inherited `PORT` and uses NEST_PORT (default 3001) so turbo/root `.env` does not steal the API port from Next.js.
PORT="3001"
# NEST_PORT="3001"
API_PREFIX="api/v1"

# Queue
QUEUE_PREFIX="aisbp"

# Rate Limiting
RATE_LIMIT_TTL="60000"
RATE_LIMIT_MAX="100"

# CORS (use domain in production)
CORS_ORIGIN="http://localhost:3000"
# For production: CORS_ORIGIN="https://kb.aisalesbot.pro"

# Public app origin used in Supabase invite/recovery `redirectTo` (no trailing slash).
# REQUIRED in production — backend throws on the first invite/reset call when this is
# unset OR points to localhost/127.0.0.1, so a misconfigured deploy fails fast instead
# of silently emailing working "localhost" links to real users.
# NEXT_PUBLIC_APP_URL is honored as a fallback when INVITE_APP_BASE_URL is unset.
# Local dev default (when neither var is set and NODE_ENV != production): http://localhost:3000
# Production example: INVITE_APP_BASE_URL="https://kb.aisalesbot.pro"
#
# Supabase Auth → URL Configuration must also allow-list these URLs before deploy:
#   Site URL:        {INVITE_APP_BASE_URL}
#   Redirect URLs:   {INVITE_APP_BASE_URL}/auth/invite
#                    {INVITE_APP_BASE_URL}/auth/reset-password
# INVITE_APP_BASE_URL=""

# IANA timezone for business-local greetings and Node `TZ` (APP_TIMEZONE wins over TZ when set).
APP_TIMEZONE="Asia/Singapore"