# Database (Postgres via Supabase)
# Local: postgresql://postgres:postgres@localhost:54322/postgres
# Production: Use your Supabase project connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres?schema=public"

# Supabase Auth
# Local: http://localhost:54321
# Production: https://kb.aisalesbot.pro (Supabase manages this)
SUPABASE_URL="http://localhost:54321"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"

# JWT (for internal operations, Supabase handles primary auth)
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# Auth API: /auth/me requires a Supabase JWT by default. Optional strict profile row check:
# - unset or not "1": allow session if JWT validates (no profiles row required)
# - "1": reject if no row in `profiles` for this user
# AUTH_REQUIRE_PROFILE="1"
# AUTH_DEBUG="1"

# Local dev only — used by `npm run smoke:auth` / `npm run smoke:auth:write` (never commit real credentials)
# SMOKE_AUTH_EMAIL="dev-user@example.com"
# SMOKE_AUTH_PASSWORD=""
# Optional: override API base (default http://127.0.0.1:$PORT/$API_PREFIX)
# SMOKE_API_BASE_URL="http://127.0.0.1:3001/api/v1"

# GHL API (not yet implemented)
GHL_API_BASE_URL="https://services.gohighlevel.com"
GHL_CLIENT_ID=""
GHL_CLIENT_SECRET=""
GHL_REDIRECT_URI="https://kb.aisalesbot.pro/api/v1/ghl/oauth/callback"

# AI Providers (not yet implemented)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# Encryption (for sensitive data like GHL tokens)
# REQUIRED: Must be exactly 32 UTF-8 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then convert hex to UTF-8 string for this value
ENCRYPTION_KEY="your-32-byte-encryption-key-here"

# Development override - DO NOT USE IN PRODUCTION
# Allows insecure fallback key for local dev when ENCRYPTION_KEY is not set
# Set to "true" only for local development without encryption configured
ALLOW_INSECURE_DEV_KEY="false"

# App
NODE_ENV="development"
PORT="3001"
API_PREFIX="api/v1"

# Queue
QUEUE_PREFIX="aisbp"

# Rate Limiting
RATE_LIMIT_TTL="60000"
RATE_LIMIT_MAX="100"

# CORS (use domain in production)
CORS_ORIGIN="http://localhost:3000"
# For production: CORS_ORIGIN="https://kb.aisalesbot.pro"