# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aisbp?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"

# Supabase (optional - for auth)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# GHL API
GHL_API_BASE_URL="https://api.gohighlevel.com"
GHL_CLIENT_ID=""
GHL_CLIENT_SECRET=""
GHL_REDIRECT_URI=""

# AI Providers
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# App
NODE_ENV="development"
PORT="3001"
API_PREFIX="api/v1"

# Queue
QUEUE_PREFIX="aisbp"

# Rate Limiting
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX="100"