# Database (Postgres via Supabase)
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres?schema=public"

# Supabase Auth (Local or Remote)
# For local Supabase: use localhost values
# For remote Supabase: use your project values from supabase.com/dashboard
SUPABASE_URL="http://localhost:54321"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Redis (for BullMQ queues)
REDIS_HOST="localhost"
REDIS_PORT="6379"

# JWT (for internal operations, Supabase handles primary auth)
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# GHL API (not yet implemented - placeholder)
GHL_API_BASE_URL="https://api.gohighlevel.com"
GHL_CLIENT_ID=""
GHL_CLIENT_SECRET=""
GHL_REDIRECT_URI=""

# AI Providers (not yet implemented - placeholder)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# App
NODE_ENV="development"
PORT="3001"
API_PREFIX="api/v1"

# Queue
QUEUE_PREFIX="aisbp"

# Rate Limiting
RATE_LIMIT_TTL="60000"
RATE_LIMIT_MAX="100"

# CORS
CORS_ORIGIN="http://localhost:3000"