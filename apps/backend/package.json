{
  "name": "@aisbp/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-esm.mjs",
    "build": "prisma generate && pnpm -w run build:libs && nest build && node patch-dist.mjs",
    "start": "node scripts/start.mjs",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "smoke:auth:write": "node scripts/smoke-auth.mjs --write",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "smoke:orchestration-e2e": "npm run build && node dist/scripts/orchestration-local-e2e.js"
  },
  "dependencies": {
    "@aisbp/ai-provider-openai": "workspace:*",
    "@aisbp/ai-router": "workspace:*",
    "@aisbp/db": "workspace:*",
    "@aisbp/formatter": "workspace:*",
    "@aisbp/ghl-client": "workspace:*",
    "@aisbp/types": "workspace:*",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.0",
    "@prisma/client": "^5.14.0",
    "@supabase/supabase-js": "^2.43.0",
    "axios": "^1.6.0",
    "bullmq": "^5.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@aisbp/tsconfig": "workspace:*",
    "@jest/globals": "^29.7.0",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.14.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
