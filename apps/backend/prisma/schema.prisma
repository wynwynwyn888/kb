// Prisma schema for AI SaaS Business Platform
// Multi-tenant SaaS platform with Supabase Auth integration

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// PROFILES (maps to Supabase auth.users)
// ============================================================================

model Profile {
  id        String   @id @default(uuid()) // This will be set to match auth.users.id
  email     String   @unique
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agencyMemberships AgencyUser[]
  tenantMemberships TenantUser[]

  @@map("profiles")
}

// ============================================================================
// AGENCY
// ============================================================================

model Agency {
  id        String   @id @default(uuid())
  name      String
  settings  Json     @default("{}")
  /// Which provider row in agency_model_providers is used for generation (OPENAI, MINIMAX, …).
  activeAiProvider AiProvider @default(OPENAI) @map("active_ai_provider")
  /// Credits applied to new subaccount wallets when created (period total baseline).
  defaultSubaccountQuota Int @default(10000) @map("default_subaccount_quota")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users          AgencyUser[]
  tenants        Tenant[]
  modelProviders AgencyModelProvider[]
  systemPolicies AgencySystemPolicy[]
  auditLogs      AuditLog[]
  quotaAuditLogs QuotaAuditLog[]

  @@map("agencies")
}

// Agency user roles
enum AgencyRole {
  OWNER
  ADMIN
  OPERATOR
  MEMBER
}

model AgencyUser {
  id        String     @id @default(uuid())
  agencyId  String     @map("agency_id")
  profileId String     @map("profile_id")
  role      AgencyRole @default(MEMBER)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  // Relations
  agency  Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([agencyId, profileId])
  @@index([profileId])
  @@map("agency_users")
}

// ============================================================================
// TENANTS
// ============================================================================

model Tenant {
  id            String   @id @default(uuid())
  agencyId      String   @map("agency_id")
  name          String
  ghlLocationId String?  @map("ghl_location_id")
  status        String   @default("pending") // active, suspended, pending
  settings      Json     @default("{}")
  botEnabled    Boolean  @default(true)  @map("bot_enabled")
  handoverPaused Boolean @default(false) @map("handover_paused")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  agency         Agency                @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  users          TenantUser[]
  ghlConnection  TenantGhlConnection?
  promptConfigs  TenantPromptConfig[]
  modelOverrides TenantModelOverride[]
  documents      KnowledgeDocument[]
  conversations  Conversation[]
  quotaWallet    QuotaWallet?
  actionLogs     ActionLog[]
  actionIntents  ActionIntent[]
  auditLogs      AuditLog[]
  webhookEvents  WebhookEvent[]
  orchestrationLogs OrchestrationLog[]
  quotaAuditLogs    QuotaAuditLog[]
  bookingSettings    TenantBookingSettings?
  taggingSettings    TenantTaggingSettings?
  tagRules           TenantTagRule[]
  followUpSettings   TenantFollowUpSettings?
  humanEscalationSettings TenantHumanEscalationSettings?
  botProfiles        TenantBotProfile[]
  knowledgeVaults  KnowledgeVault[]

  @@unique([ghlLocationId])
  @@index([agencyId])
  @@map("tenants")
}

enum BookingMode {
  COLLECT_DETAILS_ONLY
  CHECK_AVAILABILITY
  BOOK_AFTER_CONFIRMATION
}

/// Master toggle for CRM automatic tagging (subaccount).
model TenantTaggingSettings {
  tenantId                  String   @id @map("tenant_id")
  automaticTaggingEnabled   Boolean  @default(false) @map("automatic_tagging_enabled")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_tagging_settings")
}

enum TagMatchMode {
  AI
  KEYWORD
  HYBRID
}

enum ConfidenceThreshold {
  LOW
  NORMAL
  HIGH
}

/// Configurable CRM tag rules (AI/classifier matches rule IDs only; never invent tags).
model TenantTagRule {
  id                      String               @id @default(uuid())
  tenantId                String               @map("tenant_id")
  enabled                 Boolean              @default(true)
  autoApply               Boolean              @default(false) @map("auto_apply")
  ruleName                String               @map("rule_name")
  ruleDescription         String               @map("rule_description") @db.Text
  /// Optional explicit phrases for KEYWORD / HYBRID (otherwise description tokens are used).
  keywordsJson            Json                 @default("[]") @map("keywords_json")
  crmTagId                String?              @map("crm_tag_id")
  crmTagName              String               @map("crm_tag_name")
  matchMode               TagMatchMode         @default(AI) @map("match_mode")
  confidenceThreshold     ConfidenceThreshold  @default(NORMAL) @map("confidence_threshold")
  priority                Int                  @default(0)
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_tag_rules")
}

/// Subaccount automation: CRM calendar + booking field configuration (settings only until flows ship).
model TenantBookingSettings {
  tenantId                 String      @id @map("tenant_id")
  enabled                  Boolean     @default(false)
  bookingMode              BookingMode @default(COLLECT_DETAILS_ONLY) @map("booking_mode")
  defaultGhlCalendarId     String?     @map("default_ghl_calendar_id")
  defaultGhlCalendarName   String?     @map("default_ghl_calendar_name")
  /// Per core field: `{ "name": { "enabled": true, "required": true }, ... }`
  coreFieldsJson           Json        @default("{}") @map("core_fields_json")
  customFieldsJson         Json        @default("[]") @map("custom_fields_json")
  maxBookingsPerSlot       Int         @default(1) @map("max_bookings_per_slot")
  /// After live booking confirms, send booking summary SMS to this staff number (GHL).
  internalBookingAlertEnabled Boolean @default(false) @map("internal_booking_alert_enabled")
  internalBookingAlertNumber  String? @map("internal_booking_alert_number")
  internalBookingAlertChannel String @default("GHL_MESSAGE") @map("internal_booking_alert_channel")
  internalBookingAlertTemplate String? @map("internal_booking_alert_template")
  createdAt                DateTime    @default(now()) @map("created_at")
  updatedAt                DateTime    @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_booking_settings")
}

/// Follow-up automation settings (stored only; scheduler in a later milestone).
model TenantFollowUpSettings {
  tenantId                  String   @id @map("tenant_id")
  enabled                   Boolean  @default(false)
  maxFollowUps              Int      @default(3) @map("max_follow_ups")
  stopOnCustomerReply       Boolean  @default(true) @map("stop_on_customer_reply")
  stopOnBookingCompleted    Boolean  @default(true) @map("stop_on_booking_completed")
  stopOnEscalated           Boolean  @default(true) @map("stop_on_escalated")
  stopOnOptOut              Boolean  @default(true) @map("stop_on_opt_out")
  businessHoursOnly         Boolean  @default(false) @map("business_hours_only")
  /// BUSINESS (agency/workspace TZ) or CONTACT — stored for future scheduler.
  activeHoursTimezoneMode   String   @default("BUSINESS") @map("active_hours_timezone_mode")
  /// Per weekday windows: `{ "mon": { "enabled", "start", "end" }, ... }`
  activeHoursWindowsJson    Json     @default("{}") @map("active_hours_windows_json")
  stepsJson                 Json     @default("[]") @map("steps_json")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_follow_up_settings")
}

/// Human escalation: internal team notify + runtime handover when customer asks for a person.
model TenantHumanEscalationSettings {
  tenantId                 String   @id @map("tenant_id")
  enabled                  Boolean  @default(false)
  teamNotificationNumber   String?  @map("team_notification_number")
  optionalMessagePrefix    String?  @map("optional_message_prefix")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_human_escalation_settings")
}

/// Per-conversation scheduled follow-up jobs (worker-driven).
model ConversationFollowUpJob {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  conversationId  String   @map("conversation_id")
  contactId       String   @map("contact_id")
  ghlLocationId   String   @map("ghl_location_id")
  stepNumber      Int      @map("step_number")
  scheduleVersion Int      @map("schedule_version")
  scheduledAt     DateTime @map("scheduled_at")
  dueAt           DateTime @map("due_at")
  status          String   @default("PENDING")
  decidedAt       DateTime? @map("decided_at")
  sentAt          DateTime? @map("sent_at")
  decisionReason  String?  @map("decision_reason")
  decisionMeta    Json     @default("{}") @map("decision_meta")
  lastDeferReason String?  @map("last_defer_reason")
  lastDeferMeta   Json     @default("{}") @map("last_defer_meta")
  stepSnapshotJson Json    @default("{}") @map("step_snapshot_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([conversationId])
  @@index([status])
  @@index([dueAt])
  @@map("conversation_follow_up_jobs")
}

// Tenant user roles
enum TenantRole {
  ADMIN
  AGENT
  VIEWER
}

// GHL connection status
enum GhlConnectionStatus {
  DISCONNECTED
  CONNECTED
  INVALID
  ERROR
}

model TenantUser {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  profileId String    @map("profile_id")
  role      TenantRole @default(VIEWER)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([tenantId, profileId])
  @@index([profileId])
  @@map("tenant_users")
}

// ============================================================================
// GHL INTEGRATION
// ============================================================================

model TenantGhlConnection {
  id                     String            @id @default(uuid())
  tenantId               String            @unique @map("tenant_id")
  ghlLocationId          String            @map("ghl_location_id")

  // Private Integration token - stored encrypted
  // TODO: Implement proper encryption at rest (e.g., Supabase Vault, AWS KMS, or app-level AES)
  // For now, base64 encoding as placeholder - DO NOT use in production without real encryption
  privateTokenEncrypted  String            @map("private_token_encrypted")

  // Token metadata (non-secret, stored plaintext)
  scopesSnapshot         String?           @map("scopes_snapshot")
  tokenIssuedAt          DateTime?         @map("token_issued_at")
  tokenExpiresAt         DateTime?         @map("token_expires_at")

  // Connection state
  status                 GhlConnectionStatus @default(DISCONNECTED)
  verifiedAt             DateTime?         @map("verified_at")
  lastHealthCheckAt      DateTime?         @map("last_health_check_at")
  lastError              String?           @map("last_error")

  // Safe metadata (non-secret)
  metadata               Json             @default("{}")

  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_ghl_connections")
}

// ============================================================================
// AI / MODEL PROVIDERS
// ============================================================================

enum AiProvider {
  OPENAI
  ANTHROPIC
  GOOGLE
  AZURE
  CUSTOM
  MINIMAX
}

model AgencyModelProvider {
  id        String     @id @default(uuid())
  agencyId  String     @map("agency_id")
  provider  AiProvider
  apiKey    String     @map("api_key")
  endpoint  String?
  settings  Json       @default("{}")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  // Relations
  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, provider])
  @@map("agency_model_providers")
}

model AgencySystemPolicy {
  id        String   @id @default(uuid())
  agencyId  String   @map("agency_id")
  name      String
  content   String   @db.Text
  priority  Int      @default(0)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@map("agency_system_policies")
}

model TenantPromptConfig {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  name            String
  systemPrompt    String   @db.Text @map("system_prompt")
  temperature     Float    @default(0.7)
  modelOverride   String?  @map("model_override")
  maxTokens       Int?     @map("max_tokens")
  promptVariables Json     @default("{}") @map("prompt_variables")
  isActive        Boolean  @default(true) @map("is_active")
  botProfileId    String?  @unique @map("bot_profile_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  botProfile TenantBotProfile? @relation(fields: [botProfileId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_prompt_configs")
}

/// Per-workspace assistant / bot profile (persona, goals, notes, behavior). One active per tenant.
model TenantBotProfile {
  id                        String   @id @default(uuid())
  tenantId                  String   @map("tenant_id")
  name                      String
  description               String   @default("") @db.Text
  persona                   String   @default("") @db.Text
  conversationGoals         String   @default("") @map("conversation_goals") @db.Text
  businessNotes             String   @default("") @map("business_notes") @db.Text
  toneRules                 String   @default("") @map("tone_rules") @db.Text
  bookingBehaviorNotes      String   @default("") @map("booking_behavior_notes") @db.Text
  escalationBehaviorNotes   String   @default("") @map("escalation_behavior_notes") @db.Text
  knowledgeScopeNotes       String   @default("") @map("knowledge_scope_notes") @db.Text
  /// all_workspace_knowledge | selected_collections (legacy; use knowledgeAccessMode for vaults)
  knowledgeScopeMode        String   @default("all_workspace_knowledge") @map("knowledge_scope_mode")
  /// all_vaults | selected_vaults — controls KB retrieval for this profile when active
  knowledgeAccessMode       String   @default("all_vaults") @map("knowledge_access_mode")
  isActive                  Boolean  @default(false) @map("is_active")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  tenant              Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promptConfig        TenantPromptConfig?
  knowledgeVaultLinks TenantBotProfileKnowledgeVault[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("tenant_bot_profiles")
}

model TenantModelOverride {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  provider  AiProvider
  model     String
  temperature Float?   @map("temperature")
  maxTokens Int?       @map("max_tokens")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@map("tenant_model_overrides")
}

// ============================================================================
// KNOWLEDGE BASE
// ============================================================================

/// Groups knowledge documents for assistant profile access control.
model KnowledgeVault {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?  @db.Text
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents    KnowledgeDocument[]
  profileLinks TenantBotProfileKnowledgeVault[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("knowledge_vaults")
}

model TenantBotProfileKnowledgeVault {
  profileId String @map("profile_id")
  vaultId   String @map("vault_id")

  profile TenantBotProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  vault   KnowledgeVault   @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@id([profileId, vaultId])
  @@index([vaultId])
  @@map("tenant_bot_profile_knowledge_vaults")
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

/// Explicit KB entry kind for APIs (faq | rich_text | file | manual | …).
model KnowledgeDocument {
  id        String         @id @default(uuid())
  tenantId  String         @map("tenant_id")
  vaultId   String         @map("vault_id")
  title     String
  source    String
  mimeType  String         @map("mime_type")
  size      Int
  /// faq | rich_text | file | manual | …
  documentKind String      @default("manual") @map("document_kind")
  status    DocumentStatus @default(PENDING)
  metadata  Json           @default("{}")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vault  KnowledgeVault   @relation(fields: [vaultId], references: [id], onDelete: Restrict)
  chunks KnowledgeChunk[]

  @@index([tenantId])
  @@index([vaultId])
  @@map("knowledge_documents")
}

// Note: embedding column will be added later when pgvector is enabled
// For now, we store chunks without vectors
model KnowledgeChunk {
  id          String   @id @default(uuid())
  documentId  String   @map("document_id")
  content     String   @db.Text
  tokenCount  Int      @map("token_count")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("knowledge_chunks")
}

// ============================================================================
// CONVERSATIONS & MESSAGES
// ============================================================================

enum ConversationChannel {
  WHATSAPP
  SMS
  CHAT
  EMAIL
}

enum ConversationStatus {
  ACTIVE
  HANDOVER
  CLOSED
  PENDING
  PAUSED
}

model Conversation {
  id                String              @id @default(uuid())
  tenantId          String              @map("tenant_id")
  ghlConversationId String              @map("ghl_conversation_id")
  contactId         String              @map("contact_id")
  channel           ConversationChannel
  status            ConversationStatus  @default(PENDING)
  lastMessageAt     DateTime            @map("last_message_at")
  metadata          Json                @default("{}")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages   Message[]
  handovers  HandoverEvent[]
  actionLogs ActionLog[]
  actionIntents ActionIntent[]
  automationEvents ConversationAutomationEvent[]

  @@unique([ghlConversationId])
  @@index([tenantId])
  @@map("conversations")
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageSender {
  CONTACT
  AI
  AGENT
  SYSTEM
}

enum ContentType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

model Message {
  id             String          @id @default(uuid())
  conversationId String          @map("conversation_id")
  direction      MessageDirection
  sender         MessageSender
  content        String          @db.Text
  contentType    ContentType     @default(TEXT)
  metadata       Json            @default("{}")
  createdAt      DateTime        @default(now()) @map("created_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

// ============================================================================
// HANDOVER
// ============================================================================

enum HandoverType {
  REQUEST
  TRANSFER
}

enum HandoverStatus {
  ACTIVE
  RESUMED
  TIMEOUT
}

model HandoverEvent {
  id            String         @id @default(uuid())
  conversationId String        @map("conversation_id")
  type          HandoverType
  status        HandoverStatus @default(ACTIVE)
  initiatedBy   String         @map("initiated_by") // contact, ai, agent
  note          String?
  resumedAt      DateTime?      @map("resumed_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("handover_events")
}

// ============================================================================
// AUTOMATION CONTROL
// ============================================================================

model ConversationAutomationEvent {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  previousState  String?   @map("previous_state")
  newState       String    @map("new_state")
  actorId        String?   @map("actor_id")
  actorEmail     String?   @map("actor_email")
  reason         String?
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("conversation_automation_events")
}

// ============================================================================
// QUOTA
// ============================================================================

model QuotaWallet {
  id          String   @id @default(uuid())
  tenantId    String   @unique @map("tenant_id")
  totalQuota  Int      @default(0) @map("total_quota")
  usedQuota   Int      @default(0) @map("used_quota")
  /// Allow balance to go below zero (credits model).
  allowNegativeCredits Boolean @default(false) @map("allow_negative_credits")
  /// Minimum allowed balance (negative). Block when balance <= limit.
  negativeCreditLimit  Int     @default(0) @map("negative_credit_limit")
  /// When balance <= threshold, surface warning in UI.
  lowCreditThreshold   Int     @default(0) @map("low_credit_threshold")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger QuotaLedger[]

  @@map("quota_wallets")
}

enum QuotaTransactionType {
  CREDIT
  DEBIT
}

model QuotaLedger {
  id            String              @id @default(uuid())
  walletId      String              @map("wallet_id")
  amount        Int
  type          QuotaTransactionType
  /// Higher-level movement category for Credits UI + reporting.
  movementType  String?             @map("movement_type")
  /// Wallet balance after this movement (optional for legacy rows).
  balanceAfter  Int?                @map("balance_after")
  /// Idempotency key to prevent double-debits on retries.
  idempotencyKey String?            @map("idempotency_key")
  description   String
  conversationId String?            @map("conversation_id")
  metadata      Json?               @map("metadata")
  createdByUserId String?           @map("created_by_user_id")
  createdAt     DateTime            @default(now()) @map("created_at")

  // Relations
  wallet QuotaWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@map("quota_ledgers")
}

/// Agency-scoped record of manual quota default changes and per-subaccount top-ups.
model QuotaAuditLog {
  id            String   @id @default(uuid())
  agencyId      String   @map("agency_id")
  profileId     String   @map("profile_id")
  tenantId      String?  @map("tenant_id")
  action        String
  /// Credits delta for top-up; 0 for default-only events.
  delta         Int      @default(0)
  previousTotal Int?     @map("previous_total")
  newTotal      Int?     @map("new_total")
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")

  agency Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([tenantId])
  @@index([createdAt])
  @@map("quota_audit_logs")
}

// ============================================================================
// ACTION LOGS
// ============================================================================

enum ActionType {
  TAG_CONTACT
  UPDATE_CALENDAR
  SEND_REPLY
  KB_RETRIEVE
  AI_GENERATE
}

enum ActionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ActionIntentStatus {
  SUGGESTED
  ALLOWED
  DEFERRED
  BLOCKED
  EXECUTED
  FAILED
}

model ActionLog {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  conversationId String?      @map("conversation_id")
  actionType     ActionType   @map("action_type")
  status         ActionStatus @default(PENDING)
  details        Json         @default("{}")
  error          String?
  createdAt      DateTime     @default(now()) @map("created_at")

  // Relations
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("action_logs")
}

model ActionIntent {
  id             String             @id @default(uuid())
  tenantId       String             @map("tenant_id")
  conversationId String?            @map("conversation_id")
  actionType     ActionType         @map("action_type")
  source         String             @default("AI")       @map("source")
  status         ActionIntentStatus @default(SUGGESTED) @map("status")
  params         Json               @default("{}")
  reason         String?
  gatingNote     String?            @map("gating_note")
  executedAt     DateTime?          @map("executed_at")
  createdAt      DateTime           @default(now()) @map("created_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@unique([tenantId, conversationId, actionType, source])
  @@index([tenantId])
  @@index([conversationId])
  @@index([status])
  @@map("action_intents")
}

// ============================================================================
// AUDIT LOGS
// ============================================================================

model AuditLog {
  id          String   @id @default(uuid())
  agencyId    String   @map("agency_id")
  profileId   String   @map("profile_id")
  tenantId    String?  @map("tenant_id")
  action      String
  resource    String
  resourceId  String?  @map("resource_id")
  changes     Json     @default("{}")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  agency Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([profileId])
  @@map("audit_logs")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

enum NotificationType {
  HANDOVER
  QUOTA_WARNING
  KB_INGEST_COMPLETE
  ERROR
}

// ============================================================================
// WEBHOOK EVENTS
// ============================================================================

enum WebhookProvider {
  GHL
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  FAILED
  DUPLICATE
}

model WebhookEvent {
  id                    String                   @id @default(uuid())
  tenantId              String                   @map("tenant_id")
  externalEventId       String                   @map("external_event_id")
  dedupeKey             String                   @map("dedupe_key")
  provider              WebhookProvider         @default(GHL)
  eventType             String                   @map("event_type")
  rawPayloadJson        Json                     @map("raw_payload_json")
  normalizedPayloadJson Json?                    @map("normalized_payload_json")
  processingStatus      WebhookProcessingStatus @default(RECEIVED) @map("processing_status")
  processingError       String?                  @map("processing_error")
  receivedAt            DateTime                 @default(now()) @map("received_at")
  processedAt           DateTime?                @map("processed_at")
  createdAt             DateTime                 @default(now()) @map("created_at")

  tenant                Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalEventId])
  @@index([tenantId])
  @@index([processingStatus])
  @@map("webhook_events")
}

// ============================================================================
// ORCHESTRATION LOG
// ============================================================================

enum OrchestrationOutcome {
  PROCEED
  SKIP_BOT_DISABLED
  SKIP_GHL_DISCONNECTED
  SKIP_AUTOMATION_PAUSED
  SKIP_HANDOVER_ACTIVE
  SKIP_QUOTA_EXHAUSTED
  SKIP_UNSUPPORTED_MESSAGE_TYPE
  SKIP_UNSUPPORTED_CHANNEL
  SKIP_DUPLICATE
  ERROR
}

model OrchestrationLog {
  id             String               @id @default(uuid())
  tenantId       String               @map("tenant_id")
  conversationId String               @map("conversation_id")
  webhookEventId String?              @map("webhook_event_id")
  outcome        OrchestrationOutcome @default(ERROR)
  guardReason    String?              @map("guard_reason")
  modelChosen    String?              @map("model_chosen")
  responseMode   String?              @map("response_mode")
  draftReply     String?              @map("draft_reply")
  handoverRecommended Boolean          @default(false) @map("handover_recommended")
  confidence     Float?
  metadata       Json                 @default("{}")
  createdAt      DateTime             @default(now()) @map("created_at")

  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationId])
  @@map("orchestration_logs")
}

model Notification {
  id        String           @id @default(uuid())
  profileId String           @map("profile_id")
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json             @default("{}")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([profileId])
  @@map("notifications")
}