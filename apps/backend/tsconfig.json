{
  "extends": "@aisbp/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": ["ES2022", "dom"],
    "types": ["node", "jest"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "prisma", "src/**/*.spec.ts", "src/**/*.test.ts", "src/test/**/*", "src/integration/**/*"],
  "references": [
    { "path": "../../packages/types" },
    { "path": "../../packages/db" },
    { "path": "../../packages/ghl-client" },
    { "path": "../../packages/ai-router" },
    { "path": "../../packages/formatter" }
  ]
}