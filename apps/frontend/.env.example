# Supabase (browser — must match the project your backend uses)
# Local CLI: http://127.0.0.1:54321  |  Hosted: https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# App URL (redirects, OAuth callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional — server-side only; Next BFF proxies /api/v1 to Nest (default http://127.0.0.1:3001).
# BACKEND_URL=http://127.0.0.1:3001
# BACKEND_DEV_URL=http://127.0.0.1:3001