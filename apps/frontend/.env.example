# Supabase (browser — must match the project your backend uses)
# Local CLI: http://127.0.0.1:54321  |  Hosted: https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# App URL (redirects, OAuth callbacks) — must match the Next dev port (default 3000).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# If 3000 is taken: set FRONTEND_PORT (e.g. 3002), then match NEXT_PUBLIC_APP_URL and backend CORS_ORIGIN to that origin.
# FRONTEND_PORT=3002

# Optional — server-side only; Next BFF proxies /api/v1 to Nest (default http://127.0.0.1:3001).
# BACKEND_URL=http://127.0.0.1:3001
# BACKEND_DEV_URL=http://127.0.0.1:3001

# IANA timezone for date labels / “updated” copy in the UI (defaults in code to Asia/Singapore if unset).
NEXT_PUBLIC_APP_TIMEZONE="Asia/Singapore"