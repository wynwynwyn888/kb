# Supabase
# Local: http://localhost:54321
# Production: Use your Supabase project URL (managed by Supabase)
NEXT_PUBLIC_SUPABASE_URL="http://localhost:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Backend API
# Local development
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
# Production: NEXT_PUBLIC_API_URL="https://kb.aisalesbot.pro/api/v1"

# App URL (for redirects, OAuth callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_APP_URL="https://kb.aisalesbot.pro"