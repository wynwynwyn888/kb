{
  "name": "@aisbp/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/next-dev.mjs",
    "dev:clean": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }); } catch (_) {}\" && node scripts/next-dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@supabase/supabase-js": "^2.43.0",
    "@aisbp/formatter": "workspace:*",
    "@aisbp/types": "workspace:*",
    "@aisbp/tsconfig": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0"
  }
}