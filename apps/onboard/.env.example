# Onboard App URL (local dev default)
NEXT_PUBLIC_ONBOARD_APP_URL="http://localhost:3002"

# Supabase (same project as KB)
# Get these from Supabase Dashboard → Settings → API
# Must match the Supabase project your backend uses.
NEXT_PUBLIC_SUPABASE_URL="<FILL_ME>"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<FILL_ME>"

# IANA timezone for date labels
NEXT_PUBLIC_APP_TIMEZONE="Asia/Singapore"
