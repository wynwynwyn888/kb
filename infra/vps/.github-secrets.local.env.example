# Copy to infra/vps/.github-secrets.local.env (gitignored), fill real values, then run:
#   pwsh infra/vps/scripts/set-github-secrets.ps1
#   bash infra/vps/scripts/set-github-secrets.sh   (needs bash 4+)
#
# Scripts validate all keys, run `gh auth status`, then require typing YES before upload.
# They never print secret values. HOSTINGER_VM_ID is a GitHub *variable*; the rest are *secrets*.

HOSTINGER_API_KEY=
HOSTINGER_VM_ID=

DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
ENCRYPTION_KEY=
CORS_ORIGIN=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
