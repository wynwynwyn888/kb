# Copy to infra/vps/.env — used by docker compose from this directory as project root.
#
# Database: use Supabase hosted Postgres (Dashboard → Project Settings → Database → URI).
# Prefer the pooler (port 6543) or direct (5432) per Supabase docs; include ?sslmode=require if required.

DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# --- Redis (Compose service name `redis`) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Supabase (hosted): backend + browser ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Backend reads SUPABASE_ANON_KEY (see apps/backend/src/lib/supabase/index.ts).

# Browser (baked into Next at image build time — must be set when you run `docker compose build`)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Backend secrets ---
JWT_SECRET=
ENCRYPTION_KEY=
ALLOW_INSECURE_DEV_KEY=false

# --- Public site URL (Nest CORS; use https://your-domain, no trailing slash) ---
CORS_ORIGIN=https://your-domain.example.com

# --- Ports published on the VPS host ---
FRONTEND_PUBLISH_PORT=3000
# Nest is not published by default (Next BFF proxies /api/v1). Optional direct API access:
# BACKEND_PUBLISH_PORT=3001  → add a ports: mapping in docker-compose.yml if you need it.

PORT=3001

# --- Optional ---
# SKIP_PRISMA_MIGRATE=1
# GHL_* OPENAI_* — see apps/backend/.env.example
